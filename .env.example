# ============================================================================
# Environment Variables for moorenewtonwebsite
# Copy this file to .env.local and fill in real values for local development
# ============================================================================

# ----------------------------------------------------------------------------
# PUBLIC (safe for client bundle, prefixed NEXT_PUBLIC_)
# ----------------------------------------------------------------------------

# Canonical site origin (used for OG tags, sitemaps, canonical URLs)
# NEXT_PUBLIC_SITE_URL=https://www.moorenewton.com

# Sanity CMS configuration
# NEXT_PUBLIC_SANITY_PROJECT_ID=3mozn5ff
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# HubSpot Forms configuration
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=
# NEXT_PUBLIC_HUBSPOT_QUOTE_FORM_ID=
# NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_ID=

# Google Analytics 4
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Embed API key (for /contact page map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----------------------------------------------------------------------------
# SERVER-ONLY (never exposed to client)
# ----------------------------------------------------------------------------

# Sanity read token for preview/draft content
# SANITY_API_READ_TOKEN=

# Sanity webhook secret for /api/revalidate signature verification
# SANITY_WEBHOOK_SECRET=

# HubSpot private app token (reserved for future server-side API calls)
# HUBSPOT_PRIVATE_APP_TOKEN=

# ----------------------------------------------------------------------------
# DMSI Agility ERP integration (reserved for future, unset in v1)
# ----------------------------------------------------------------------------

# AGILITY_API_BASE_URL=
# AGILITY_API_KEY=
# AGILITY_CUSTOMER_ID=
