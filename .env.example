# ============================================================================
# Environment Variables for moorenewtonwebsite
# Copy this file to .env.local and fill in real values for local development
# ============================================================================

# ----------------------------------------------------------------------------
# PUBLIC (safe for client bundle, prefixed NEXT_PUBLIC_)
# ----------------------------------------------------------------------------

# Canonical site origin (used for OG tags, sitemaps, canonical URLs)
# MUST include https:// protocol. Used at build time.
# Staging: https://moorenewtonwebsite-production.up.railway.app
# Production: https://www.moorenewton.com
NEXT_PUBLIC_SITE_URL=https://www.moorenewton.com

# Sanity CMS configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=3mozn5ff
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# HubSpot Forms configuration
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=5302852
NEXT_PUBLIC_HUBSPOT_QUOTE_FORM_ID=223ad648-c6d8-46c4-ad68-10e3be6622fe
NEXT_PUBLIC_HUBSPOT_CONTACT_FORM_ID=ebecd94b-2fd6-4322-8203-b0bdaddbf38a
HUBSPOT_REGION=na2

# Google Analytics 4
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Embed API key (for /contact page map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----------------------------------------------------------------------------
# SERVER-ONLY (never exposed to client)
# ----------------------------------------------------------------------------

# Sanity read token for preview/draft content (server-only)
SANITY_API_READ_TOKEN=

# Sanity write token for migration scripts (server-only)
# Create at: https://www.sanity.io/manage/project/<projectId>/api#tokens
SANITY_API_WRITE_TOKEN=

# Sanity revalidation secret for /api/revalidate webhook (server-only)
SANITY_REVALIDATE_SECRET=

# HubSpot private app token (reserved for future server-side API calls)
# HUBSPOT_PRIVATE_APP_TOKEN=

# ----------------------------------------------------------------------------
# DMSI Agility ERP integration (reserved for future, unset in v1)
# ----------------------------------------------------------------------------

# AGILITY_API_BASE_URL=
# AGILITY_API_KEY=
# AGILITY_CUSTOMER_ID=
